# Copy this file to .env and fill in your real values. Never commit .env!

# Found in Discord Developer Portal -> Bot -> Token
DISCORD_TOKEN=your_bot_token_here

# Found in Discord Developer Portal -> General Information -> Application ID
CLIENT_ID=your_application_client_id_here

# Right-click your server icon in Discord -> Copy Server ID (enable Developer Mode in Discord settings first)
# Used for instant command deployment during testing. Remove this line for global deployment.
GUILD_ID=your_server_id_here
