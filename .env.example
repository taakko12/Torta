# Copy this file to .env and fill in your real values. Never commit .env!

# Found in Discord Developer Portal -> Bot -> Token
DISCORD_TOKEN=your_bot_token_here

# Found in Discord Developer Portal -> General Information -> Application ID
CLIENT_ID=your_application_client_id_here

# Right-click your server icon in Discord -> Copy Server ID (enable Developer Mode in Discord settings first)
# Used for instant command deployment during testing. Remove this line for global deployment.
GUILD_ID=your_server_id_here

# Your clan's Wise Old Man Group ID. Find it in the URL of your clan's WOM
# group page, e.g. https://wiseoldman.net/groups/12345 -> GROUP_ID is 12345
WOM_GROUP_ID=your_wom_group_id_here

# WOM group verification code — found on your WOM group settings page.
# Required for the bot to auto-create BOTW/SOTW competitions on WOM.
# Format: XXX-XXX-XXX (hyphens are fine)
WOM_GROUP_VERIFICATION_CODE=your_wom_verification_code_here

# Optional but recommended: helps WOM identify your bot instead of IP-banning
# it if something goes wrong. Just put your Discord username or clan name.
WOM_USER_AGENT=your_discord_name_here

# Optional: request a free API key from the WOM Discord to raise your rate
# limit from 20 req/min to 100 req/min. Leave blank if you don't have one.
WOM_API_KEY=

# Supabase — found in Settings → API in your Supabase dashboard
# The bot uses the service role key (server-side, bypasses RLS).
# The website uses the anon key (public read-only).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# TrackScape RuneLite plugin integration
# Set TRACKSCAPE_PUBLIC_URL to your Railway deployment URL (e.g. https://torta-bot.up.railway.app)
# Leave blank when running locally and set TRACKSCAPE_HOST=your-local-ip:3000 instead.
TRACKSCAPE_PUBLIC_URL=
TRACKSCAPE_PORT=3000
